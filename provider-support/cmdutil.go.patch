+// providerOptions holds request options resolved during the Before hook for
+// Vertex AI or Bedrock providers. Empty for the default Anthropic provider.
+var providerOptions []option.RequestOption
+
+// initProvider is the Before hook on the root command. It resolves provider-specific
+// request options once, before any subcommand handler runs.
+func initProvider(ctx context.Context, cmd *cli.Command) (context.Context, error) {
+	provider := cmd.String("provider")
+	region := cmd.String("region")
+
+	switch provider {
+	case "", "anthropic":
+		return ctx, nil
+
+	case "vertex":
+		projectID := cmd.String("project-id")
+		if region == "" {
+			region = os.Getenv("GOOGLE_CLOUD_REGION")
+		}
+		if region == "" {
+			return ctx, fmt.Errorf("--region is required for vertex provider (or set GOOGLE_CLOUD_REGION)")
+		}
+		if projectID == "" {
+			return ctx, fmt.Errorf("--project-id is required for vertex provider (or set GOOGLE_CLOUD_PROJECT)")
+		}
+		opt, err := initVertexProvider(region, projectID)
+		if err != nil {
+			return ctx, err
+		}
+		providerOptions = []option.RequestOption{opt}
+		return ctx, nil
+
+	case "bedrock":
+		if region == "" {
+			region = os.Getenv("AWS_REGION")
+			if region == "" {
+				region = os.Getenv("AWS_DEFAULT_REGION")
+			}
+		}
+		if region == "" {
+			return ctx, fmt.Errorf("--region is required for bedrock provider (or set AWS_REGION)")
+		}
+		opt, err := safeBedrockAuth(region)
+		if err != nil {
+			return ctx, err
+		}
+		providerOptions = []option.RequestOption{opt}
+		return ctx, nil
+
+	default:
+		return ctx, fmt.Errorf("unsupported provider: %s (must be anthropic, vertex, or bedrock)", provider)
+	}
+}
+
+// safeBedrockAuth wraps bedrock.WithLoadDefaultConfig with panic recovery.
+func safeBedrockAuth(region string) (opt option.RequestOption, err error) {
+	defer func() {
+		if r := recover(); r != nil {
+			err = fmt.Errorf("bedrock auth failed: %v", r)
+		}
+	}()
+	ctx := context.Background()
+	opt = bedrock.WithLoadDefaultConfig(ctx, config.WithRegion(region))
+	return
+}
